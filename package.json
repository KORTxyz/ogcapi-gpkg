{
  "name": "@kortxyz/ogcapi-gpkg",
  "version": "0.4.5",
  "main": "src/index.js",
  "type": "module",
  "bin": "test/server.js",
  "scripts": {
    "start": "node --env-file=.env --watch ./test/server",
    "compileTailwind": "npx tailwindcss -o ./src/assets/tailwind.css --minify",
    "copy-redoc": "cp node_modules/redoc/bundles/redoc.standalone.js src/assets/",
    "copy-kc": "cp -r node_modules/@kortxyz/kortxyz-components/dist/kortxyz-components/* src/assets/",
    "test": "node --env-file=.env --test ./test/common.test.js ./test/features.test.js ./test/tiles.test.js ./test/styles.test.js",
    "build": "pkg --targets node24-win-x64 -o KORTxyz.exe ."
  },
  "keywords": [],
  "author": "Tino Kastbjerg Stigsen",
  "license": "MIT",
  "description": "Fastify plugin for turning a OGC GPKG file into an OGC API.",
  "dependencies": {
    "@fastify/accepts": "^5.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/view": "^11.1.1",
    "@kortxyz/geostyler-mapbox-parser": "^6.1.2",
    "@kortxyz/geostyler-sld-parser-esm": "^7.0.1",
    "@ngageoint/projections-js": "^1.0.2",
    "@ngageoint/simple-features-geojson-js": "^1.1.1",
    "@ngageoint/simple-features-proj-js": "^1.1.3",
    "@ngageoint/simple-features-wkb-js": "^1.1.1",
    "@tailwindcss/cli": "^4.2.1",
    "better-sqlite3": "^12.6.2",
    "eta": "^4.5.1",
    "fastify": "^5.8.1",
    "fastify-openapi-glue": "^4.10.2",
    "geojson-vt": "^4.0.2",
    "magic-bytes.js": "^1.13.0",
    "tailwindcss": "^4.2.1",
    "vt-pbf": "^3.1.3"
  },
  "overrides": {
    "@kortxyz/kortxyz-components": {
      "d3-color": "3.1.0"
    }
  },
  "devDependencies": {
    "@fastify/cors": "^11.2.0",
    "@kortxyz/kortxyz-components": "^0.5.5",
    "redoc": "^2.5.2"
  },
  "pkg": {
    "scripts": [],
    "assets": [
      "src/assets/*",
      "src/views/*",
      "src/openapi.yaml",
      "node_modules/better-sqlite3/build/Release/*",
      "node_modules/@seriousme/openapi-schema-validator/schemas/v3.0/schema.json"
    ]
  }
}
